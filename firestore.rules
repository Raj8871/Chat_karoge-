rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - uniqueId: string (required, unique)
    //   - displayName: string (required)
    //   - photoURL: string
    //   - bio: string
    //   - status: string (online/offline)
    //   - lastSeen: timestamp
    //   - role: string (user/admin)
    //
    // Collection: chats
    // Fields:
    //   - participants: list of strings (UIDs)
    //   - participantIds: list of strings (Unique IDs)
    //   - lastMessage: string
    //   - updatedAt: timestamp
    //
    // Collection: messages (subcollection of chats)
    // Fields:
    //   - from: string (UID)
    //   - to: string (UID)
    //   - text: string
    //   - type: string (text/image)
    //   - image: string
    //   - timestamp: timestamp
    //   - status: string (sent/delivered/read)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin') ||
         (request.auth.token.email == "rajan88711@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isParticipant(chatId) {
      return isAuthenticated() && 
             (
               chatId.matches(".*" + request.auth.uid + ".*") ||
               (exists(/databases/$(database)/documents/chats/$(chatId)) && 
                request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants)
             );
    }

    function isRecent(time) {
      return time > request.time - duration.value(10, 'm') &&
             time < request.time + duration.value(10, 'm');
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'uniqueId', 'displayName']) &&
             data.uid is string &&
             data.uniqueId is string && data.uniqueId.size() >= 3 && data.uniqueId.size() <= 30 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100 &&
             (!('bio' in data) || data.bio == null || (data.bio is string && data.bio.size() <= 1000)) &&
             (!('status' in data) || data.status == null || (data.status is string && data.status.size() <= 50));
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['from', 'to', 'type', 'timestamp']) &&
             data.from is string &&
             data.to is string &&
             data.type in ['text', 'image', 'document', 'video', 'audio'] &&
             (!('text' in data) || data.text == null || (data.text is string && data.text.size() <= 5000)) &&
             (!('image' in data) || data.image == null || (data.image is string)) &&
             (!('video' in data) || data.video == null || (data.video is string)) &&
             (!('audio' in data) || data.audio == null || (data.audio is string)) &&
             (!('document' in data) || data.document == null || (data.document is map)) &&
             (!('isDeleted' in data) || data.isDeleted is bool) &&
             (!('deletedFor' in data) || data.deletedFor is list) &&
             (!('status' in data) || data.status is string) &&
             (!('replyTo' in data) || data.replyTo == null || data.replyTo is map);
    }

    function isValidChat(data) {
      return (!('participants' in data) || (data.participants is list)) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp || data.updatedAt == null) &&
             (!('lastTimestamp' in data) || data.lastTimestamp is timestamp || data.lastTimestamp == null) &&
             (!('participantIds' in data) || (data.participantIds is list)) &&
             (!('lastMessage' in data) || data.lastMessage == null || (data.lastMessage is string && data.lastMessage.size() <= 1000)) &&
             (!('deletedAt' in data) || data.deletedAt is map || data.deletedAt == null) &&
             (!('id' in data) || data.id is string);
    }

    function isFriend(uid1, uid2) {
      let friendId = uid1 < uid2 ? uid1 + '_' + uid2 : uid2 + '_' + uid1;
      return exists(/databases/$(database)/documents/friends/$(friendId));
    }

    function isValidSharedDocument(data) {
      return data.keys().hasAll(['ownerId', 'fileURL', 'accessCode', 'fileName', 'fileSize', 'uploadTime']) &&
             data.ownerId is string &&
             data.fileURL is string &&
             data.accessCode is string && data.accessCode.size() >= 6 &&
             data.fileName is string && data.fileName.size() > 0 &&
             data.fileSize is number &&
             data.uploadTime is timestamp;
    }

    // ===============================================================
    // User Rules
    // ===============================================================
    match /users/{uid} {
      // Allow get for search and profile viewing
      allow get: if isAuthenticated();
      // Allow list for search queries
      allow list: if isAuthenticated();
      
      allow create: if isOwner(uid) && isValidUser(request.resource.data) && 
                      (!('role' in request.resource.data) || request.resource.data.role == 'user');
      allow update: if isOwner(uid) && isValidUser(request.resource.data) && 
                      (request.resource.data.get('role', 'user') == resource.data.get('role', 'user') || isAdmin());
    }

    // ===============================================================
    // Shared Document Rules
    // ===============================================================
    match /sharedDocuments/{documentId} {
      // Allow read if owner or if user has access record or if it's a single document query (for code access)
      allow read: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid || 
        exists(/databases/$(database)/documents/userDocumentAccess/$(request.auth.uid + '_' + documentId)) ||
        request.query.limit == 1
      );
      
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid && isValidSharedDocument(request.resource.data);
      allow update: if isAuthenticated() && resource.data.ownerId == request.auth.uid && isValidSharedDocument(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    match /userDocumentAccess/{accessId} {
      // Allow get if the access record belongs to the user (even if it doesn't exist yet)
      allow get: if isAuthenticated() && (
        accessId.startsWith(request.auth.uid + "_") ||
        (resource != null && get(/databases/$(database)/documents/sharedDocuments/$(resource.data.documentId)).data.ownerId == request.auth.uid)
      );
      // Allow list if the user is the owner of the access record or the document
      allow list: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        get(/databases/$(database)/documents/sharedDocuments/$(resource.data.documentId)).data.ownerId == request.auth.uid
      );
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && accessId == request.auth.uid + "_" + request.resource.data.documentId;
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || 
                      get(/databases/$(database)/documents/sharedDocuments/$(resource.data.documentId)).data.ownerId == request.auth.uid);
    }

    // ===============================================================
    // Chat Rules
    // ===============================================================
    match /chats/{chatId} {
      allow get: if isAuthenticated() && (chatId.matches(".*" + request.auth.uid + ".*") || (resource != null && request.auth.uid in resource.data.participants));
      allow list: if isAuthenticated() && (chatId.matches(".*" + request.auth.uid + ".*") || (resource != null && request.auth.uid in resource.data.participants));
      
      allow create: if isAuthenticated() && 
                      (chatId.matches(".*" + request.auth.uid + ".*") || (request.resource.data.keys().hasAll(['participants']) && request.auth.uid in request.resource.data.participants)) && 
                      isValidChat(request.resource.data);
      allow update: if isAuthenticated() && 
                      (chatId.matches(".*" + request.auth.uid + ".*") || (resource != null && request.auth.uid in resource.data.participants)) && 
                      isValidChat(request.resource.data);
      allow delete: if isAuthenticated() && (chatId.matches(".*" + request.auth.uid + ".*") || (resource != null && request.auth.uid in resource.data.participants));

      match /messages/{messageId} {
        allow read: if isParticipant(chatId);
        allow create: if isParticipant(chatId) && request.resource.data.from == request.auth.uid && isValidMessage(request.resource.data);
        allow update: if isParticipant(chatId) && 
                        (
                          (request.resource.data.from == request.auth.uid && isValidMessage(request.resource.data)) || 
                          (request.auth.uid == resource.data.to && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])) ||
                          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletedFor']))
                        );
        allow delete: if isParticipant(chatId) && resource.data.from == request.auth.uid;
      }
    }

    // ===============================================================
    // Block Rules
    // ===============================================================
    match /blocks/{blockId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.blocker || request.auth.uid == resource.data.blocked);
      allow create: if isAuthenticated() && request.resource.data.blocker == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.blocker == request.auth.uid && request.resource.data.blocker == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.blocker == request.auth.uid;
    }

    // ===============================================================
    // Connection Request Rules
    // ===============================================================
    match /connectionRequests/{requestId} {
      allow get: if isAuthenticated();
      allow list: if isAuthenticated() && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
      
      allow create: if isAuthenticated() && request.resource.data.from == request.auth.uid && request.resource.data.status == 'pending';
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.to || request.auth.uid == resource.data.from) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
                      request.resource.data.status in ['accepted', 'rejected'];
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
    }

    match /friends/{friendId} {
      allow get: if isAuthenticated();
      allow list: if isAuthenticated() && (request.auth.uid in resource.data.uids);
      
      allow create: if isAuthenticated() && (request.auth.uid in request.resource.data.uids);
      allow delete: if isAuthenticated() && (request.auth.uid in resource.data.uids);
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
